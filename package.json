{
	"name": "home-page",
	"version": "3.6.14",
	"type": "module",
	"exports": {
		"./package.json": "./package.json",
		".": "./server/index.js"
	},
	"description": "A simple browser home page",
	"author": "justfatlard",
	"license": "ISC",
	"browserslist": [
		"last 1 version",
		"> 1%",
		"not dead",
		"not op_mini all"
	],
	"scripts": {
		"prepare": "bun run build",
		"build": "bun run build:clean && bun run client/build.js",
		"build:clean": "rm -rf ./client/build/",
		"build:watch": "bun run build -- --watch",
		"start": "NODE_ENV=production bun server/index.js",
		"dev": "NODE_ENV=development bun --hot server/index.js",
		"lint": "bun --bun eslint",
		"lint:fix": "bun --bun eslint --fix",
		"format": "bun run lint:fix && bun --bun prettier --write .",
		"version": "npm version",
		"build:dev": "bun run build && bun run service:reload",
		"service:enable": "bun scripts/service.js enable",
		"service:disable": "bun scripts/service.js disable",
		"service:start": "bun scripts/service.js start",
		"service:stop": "bun scripts/service.js stop",
		"service:reload": "bun scripts/service.js reload"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/fatlard1993/home-page.git"
	},
	"bugs": {
		"url": "https://github.com/fatlard1993/home-page/issues"
	},
	"homepage": "https://github.com/fatlard1993/home-page#readme",
	"dependencies": {
		"@ctrl/tinycolor": "^4.2.0",
		"@leeoniya/ufuzzy": "^1.0.19",
		"@vanilla-bean/components": "^2.0.1",
		"@vanilla-bean/hypertether": "^1.0.1",
		"argi": "github:fatlard1993/argi#fcac703",
		"lowdb": "^7.0.1",
		"nanoid": "^6.0.0",
		"pngjs": "^7.0.0"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@happy-dom/global-registrator": "^20.10.6",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"bun-types": "^1.3.14",
		"eslint": "^10.7.0",
		"eslint-plugin-compat": "^7.0.2",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^63.0.13",
		"eslint-plugin-spellcheck": "0.0.20",
		"eslint-plugin-testing-library": "^7.16.2",
		"eslint-plugin-unicorn": "^72.0.0",
		"eslint-plugin-write-good-comments": "^0.2.0",
		"globals": "^17.7.0",
		"prettier": "3.9.5"
	}
}
